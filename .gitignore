# =============================================================
# EEG Densification — .gitignore
# =============================================================

# ------ Large EEG data files (re-downloadable via download_eegmmidb.py) ------
pipeline_v2/data/fif/
pipeline_v2/data/fif_mi/
pipeline_v2/data/raw/
pipeline_v2/data/zuna_work/
pipeline_v2/data/zuna_work_matched/

# ------ Node (used by figure build scripts only) ----------------------
node_modules/
package-lock.json

# ------ PyTorch checkpoints and intermediate tensors ---------
*.pt
*.pth
*.ckpt

# ------ Python cache -----------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ------ Virtual environments ---------------------------------
venv/
env/
.venv/
.env/

# ------ Jupyter ---------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ------ OS / editor files ------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ------ Logs and temp ----------------------------------------
*.log
*.tmp
/tmp/

# ------ Model API keys / config (do not commit secrets) ------
*.env
secrets.yaml
api_keys.json

# ------ Large result binaries (keep only .json summaries) ----
# Uncomment if figure PNGs/PDFs become too large:
# pipeline_v2/results/figures/*.pdf
